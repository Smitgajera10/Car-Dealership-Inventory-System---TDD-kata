{
  "name": "car-dealership-inventory-system",
  "version": "1.0.0",
  "description": "Car Dealership Inventory System - Incubyte Assessment",
  "main": "src/app.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
